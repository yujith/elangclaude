# Copy to `.env` in this folder (same directory as this file):
#   cp .env.example .env
# Then paste your real Neon URLs. Never commit `.env`.
#
# Neon: use one branch for dev (migrations + seed) and a separate branch for tests.
# Prefer the pooled host for DATABASE_URL when Neon offers it.
# See README.md in this package.

# Dev branch — pnpm db:migrate:dev and pnpm db:seed use this
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Test branch — tenancy fuzzer / Vitest (DATABASE_URL is rewritten to this in tests)
DATABASE_URL_TEST="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Optional: Neon child branch (branched from dev in the Neon console). Not read by
# Prisma or Vitest automatically — use when you want an isolated copy for risky
# migrations, previews, or experiments. Example: DATABASE_URL="$DATABASE_URL_NEON_CHILD" pnpm db:migrate:dev
DATABASE_URL_NEON_CHILD="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Cloudflare R2 — Speaking recordings (signed PUT/GET). See docs/adr/0005-gateway-realtime-and-storage.md.
# Account ID: Cloudflare dashboard → any domain → Overview → Account ID (right column),
# or Workers & Pages → your account name → Account details.
# Keys: R2 → Manage R2 API Tokens → Create API token (Object Read & Write on your bucket).
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="your-bucket-name"
