{
  "name": "@elc/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./tenancy": "./src/tenancy.ts",
    "./admin-invite": "./src/admin-invite.ts",
    "./super-user-admin": "./src/super-user-admin.ts",
    "./super-metrics": "./src/super-metrics.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "seed:listening": "tsx prisma/seed-listening.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"@elc/db: lint deferred (no app code beyond what consumers check)\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@elc/ai": "workspace:*",
    "@types/node": "^20.17.6",
    "dotenv": "^16.4.5",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "schema": "prisma/schema.prisma"
  }
}
