// eLanguage Center — canonical Prisma schema.
//
// Source of truth for the data model. If this file disagrees with anything in
// docs/Brief.md or docs/ARCHITECTURE.md, this file wins — flag the drift.
//
// Conventions:
//   - cuid IDs everywhere.
//   - Tenant-scoped tables carry `org_id` + a relation back to Organization
//     with onDelete: Cascade. They are also listed in TENANT_SCOPED_MODELS in
//     src/tenancy.ts. The fuzzer in src/tenancy.test.ts asserts these match.
//   - Global tables (Organization, Test, Question) are NOT tenant-scoped.
//   - Field naming: snake_case for business fields (org_id, started_at);
//     camelCase for Prisma-managed timestamps (createdAt, updatedAt) to match
//     the canonical pattern in .claude/skills/multi-tenant-prisma/SKILL.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  SuperAdmin
  OrgAdmin
  Learner
  // Reviewer is a Phase 2 role and is intentionally omitted in MVP.
  // Adding it later is a single-line enum migration.
}

enum Track {
  Academic
  GeneralTraining
}

enum Section {
  Reading
  Listening
  Writing
  Speaking
}

enum AttemptStatus {
  InProgress
  Submitted
  Graded
  Abandoned
}

enum TestStatus {
  Draft
  PendingReview
  Approved
  Rejected
}

enum GraderKind {
  AI
  Human
}

enum OrgStatus {
  Active
  Suspended
  Archived
}

enum MockStatus {
  InProgress
  Submitted
  Abandoned
}

// Billing lifecycle of the Org's subscription. Distinct from OrgStatus
// (moderation/lifecycle). Webhook (ADR-0017 D7) flips both columns when a
// subscription cancels; SuperAdmin can flip OrgStatus alone for T&C
// reasons. See ADR-0017 D3.
//
// PendingPayment   — Org row exists, OrgAdmin has not completed Checkout.
// Trialing         — Stripe subscription in trial; full access.
// Active           — Stripe subscription past trial, paying.
// PastDue          — invoice failed; Stripe smart-retry in flight.
// Canceled         — subscription deleted; paired with OrgStatus=Suspended.
// Incomplete       — Stripe Checkout incomplete (3DS etc.); transient.
// Internal         — non-billed (Free plan, seeded orgs, system org).
enum SubscriptionStatus {
  PendingPayment
  Trialing
  Active
  PastDue
  Canceled
  Incomplete
  Internal
}

// Which funnel produced this Org. Analytics only — routing decisions
// must read `subscription_status`, never this column. See ADR-0017 D2.
enum ProvisionedVia {
  seeded
  invite
  self_serve
}

// ─── Compliance enums (ADR-0019) ──────────────────────────────────────────

// Who is the data controller for an Org's learners (GDPR Art 4 / DPDP).
//   CustomerControlled — the buying Organization is the controller and
//     eLanguage Center is the *processor* (org-seat: seeded + invite funnels).
//     These orgs are covered by the DPA + sub-processor list.
//   PlatformControlled — eLanguage Center is the *controller* directly
//     (self-serve individuals who sign up for themselves).
// Set at provisioning time; the migration backfills existing rows from
// provisioned_via. See ADR-0019 D1.
enum DataControllerModel {
  CustomerControlled
  PlatformControlled
}

// Where an Org's learner data physically lives. v1 offers a single region
// (Sydney, co-located with Neon per the region-colocation rule). The column
// exists so the Privacy Policy can disclose residency truthfully and so
// enterprise orgs can later be pinned to a region — adding a value here is a
// deliberate ADR-gated change, never an implicit one. See ADR-0019 D2.
enum DataResidencyRegion {
  syd1
}

// Coarse age band for a learner. We deliberately do NOT store full date of
// birth (data minimisation): we only need to know whether a guardian-consent
// path applies (DPDP under-18, GDPR Art 8). See ADR-0019 D3.
enum AgeAssurance {
  Unknown
  Adult
  Minor
}

// Category of consent captured in a ConsentRecord. One row per (user, type)
// state change — the latest row per type is authoritative.
enum ConsentType {
  terms_privacy // accepted ToS + Privacy Policy (sign-up gate)
  cookies_functional // non-essential functional cookies
  cookies_analytics // analytics/product telemetry (PostHog/Sentry when wired)
  voice_recording // Speaking audio capture (sensitive data)
  marketing_email // optional marketing communications
  parental // guardian consent on behalf of a minor learner
}

// Data-subject right being exercised (GDPR Ch.3 / DPDP / APPs).
enum DataRightType {
  Access // copy of what we hold
  Portability // machine-readable export
  Erasure // right to be forgotten
  Rectification // correct inaccurate data
}

enum DataRightStatus {
  Pending
  InProgress
  Completed
  Rejected
  Cancelled
}

// ─── Models — global (NOT tenant-scoped) ──────────────────────────────────

model Organization {
  id            String    @id @default(cuid())
  // Clerk organization id (`org_*`). Nullable so seeded orgs and the
  // singleton "system" org can exist without a Clerk counterpart. Set
  // by the Clerk webhook on organization.created and read by
  // requireOrgContext to map Clerk's active org to our row.
  clerk_org_id  String?   @unique
  name          String
  seat_limit    Int       @default(0)
  quota_daily   Int       @default(0)
  quota_monthly Int       @default(0)
  status        OrgStatus @default(Active)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ─── Billing (ADR-0017) ───────────────────────────────────────────────
  // Nullable initially: existing rows get backfilled to the `internal`
  // Plan by the data migration in packages/db/prisma/seed.ts. New orgs
  // (invite + self-serve flows) always set plan_id at creation.
  plan_id                String?            @map("plan_id")
  plan                   Plan?              @relation(fields: [plan_id], references: [id], onDelete: SetNull)
  // Stripe Customer object id. Created lazily on first Checkout (ADR-0017
  // D7). Unique so two Orgs can never accidentally share a customer.
  stripe_customer_id     String?            @unique
  // Stripe Subscription object id. Stamped on checkout.session.completed.
  stripe_subscription_id String?            @unique
  subscription_status    SubscriptionStatus @default(Internal)
  current_period_end     DateTime?
  trial_end              DateTime?
  // Billing-owner OrgAdmin (ADR-0017 D9). Other OrgAdmins see
  // /admin/billing but cannot open the Stripe portal.
  billing_owner_user_id  String?
  billing_owner          User?              @relation("BillingOwner", fields: [billing_owner_user_id], references: [id], onDelete: SetNull)
  provisioned_via        ProvisionedVia     @default(seeded)

  // ─── Compliance (ADR-0019) ────────────────────────────────────────────
  // CustomerControlled by default (org-seat). provisionSelfServeOrg flips
  // PlatformControlled. Drives which Privacy Policy posture applies + DSR
  // routing. The migration backfills self_serve orgs → PlatformControlled.
  controller_model DataControllerModel @default(CustomerControlled)
  data_region      DataResidencyRegion @default(syd1)

  users           User[]
  consentRecords     ConsentRecord[]
  dataRightsRequests DataRightsRequest[]
  attempts        Attempt[]
  answers         Answer[]
  grades          Grade[]
  recordings      Recording[]
  quotaUsages     QuotaUsage[]
  activityLogs    ActivityLog[]
  mockSessions    MockSession[]
  aiCallLogs      AiCallLog[]
  stripeEventLogs StripeEventLog[]

  @@index([plan_id])
  @@index([subscription_status])
}

// Subscription plan catalogue. Global model (NOT tenant-scoped) — managed
// only via withSuperAdminContext(). See ADR-0017 D5.
//
// `is_internal: true` plans (and Free, which has amount=0) never sync to
// Stripe. All other rows have a Stripe Product + monthly Price created
// by the SuperAdmin plan-actions on save.
model Plan {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  name                    String
  description             String?
  seat_limit              Int      @default(1)
  quota_daily             Int      @default(50)
  quota_monthly           Int      @default(300)
  amount_monthly_usd      Decimal  @db.Decimal(10, 2)
  currency                String   @default("usd")
  trial_days              Int      @default(14)
  is_internal             Boolean  @default(false)
  is_active               Boolean  @default(true)
  sort_order              Int      @default(0)
  stripe_product_id       String?  @unique
  stripe_price_id_monthly String?  @unique
  // Schema room for an annual price; not used in v1. See plan doc Phase
  // 7 follow-ups.
  stripe_price_id_yearly  String?  @unique
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organizations Organization[]

  @@index([is_active, sort_order])
}

// One row per received Stripe webhook event. Provides idempotency
// (unique constraint on stripe_event_id) and an ordering primitive
// (event_created_at, populated from Stripe's event.created). See
// ADR-0017 D8.
model StripeEventLog {
  id               String   @id @default(cuid())
  stripe_event_id  String   @unique
  event_type       String
  event_created_at DateTime
  // Organization the event applied to, if resolvable. Null for events
  // we couldn't map (e.g. customer.created before our app linked it).
  // onDelete: SetNull keeps the audit trail even if the Org row is
  // archived/hard-deleted later — Stripe events outlive customer rows.
  org_id           String?
  org              Organization? @relation(fields: [org_id], references: [id], onDelete: SetNull)
  payload_summary  Json?
  processed_at     DateTime @default(now())

  @@index([event_type, event_created_at])
  @@index([org_id])
}

model Test {
  id          String     @id @default(cuid())
  track       Track
  section     Section
  difficulty  Int        @default(5)
  status      TestStatus @default(Draft)
  approved_by String?
  approver    User?      @relation("TestApprover", fields: [approved_by], references: [id], onDelete: SetNull)
  // Optional passage payload for Reading (and, later, Listening transcripts).
  // Shape parsed in packages/ai/src/reading/passage.ts. Null for Writing /
  // Speaking rows. See docs/adr/0003-reading-data-shape.md.
  body_json   Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions Question[]
  attempts  Attempt[]

  @@index([track, section, status])
  @@index([approved_by])
}

model Question {
  id             String   @id @default(cuid())
  test_id        String
  test           Test     @relation(fields: [test_id], references: [id], onDelete: Cascade)
  type           String
  prompt         String
  correct_answer Json?
  // Optional visual payload for Academic T1 (bar/line/pie/table/process).
  // Shape validated in app code (apps/web/lib/writing/visual.ts) — kept as
  // Json so we can iterate on chart types without a schema migration each time.
  visual         Json?
  points         Int      @default(1)
  position       Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  answers Answer[]

  @@index([test_id])
}

// ─── Models — tenant-scoped ───────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  org_id        String
  org           Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  // Clerk user id (`user_*`). Nullable so seeded users exist before they
  // first sign in via Clerk. requireOrgContext lazy-links on first sign-in
  // by matching email; the webhook keeps it in sync afterwards.
  clerk_user_id String?
  email         String
  name          String?
  role          Role         @default(Learner)
  ielts_track   Track        @default(Academic)
  // Soft-delete timestamp. SuperAdmins can remove a user from an org
  // without losing the audit trail (Attempts / Grades / Recordings stay
  // intact). A non-null value blocks sign-in (loadOrgContext) and hides
  // the row from default rosters. Soft-deleted users still occupy a
  // seat against `Organization.seat_limit` until they are hard-purged.
  deleted_at    DateTime?
  // ─── Compliance (ADR-0019) ────────────────────────────────────────────
  // Coarse age band only — we do not store full DOB (data minimisation).
  // age_assurance=Minor requires guardian_consent_at before practice access.
  age_assurance       AgeAssurance @default(Unknown)
  guardian_email      String?
  guardian_consent_at DateTime?
  // Set when an Erasure request is actioned: PII is scrubbed in place and
  // the row is soft-deleted. Distinct from deleted_at (admin removal) so we
  // can prove an erasure was fulfilled. See ADR-0019 D4.
  erased_at           DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  attempts         Attempt[]
  quotaUsages      QuotaUsage[]
  activityLogs     ActivityLog[]
  approved_tests   Test[]         @relation("TestApprover")
  mockSessions     MockSession[]
  aiCallLogs       AiCallLog[]
  billing_owner_of Organization[] @relation("BillingOwner")
  consentRecords     ConsentRecord[]
  dataRightsRequests DataRightsRequest[]

  @@index([org_id])
  @@index([org_id, createdAt])
  @@index([org_id, role])
  @@index([org_id, deleted_at])
  @@unique([org_id, email], name: "user_org_email")
  @@unique([org_id, clerk_user_id], name: "user_org_clerk_user_id")
}

model Attempt {
  id              String        @id @default(cuid())
  org_id          String
  org             Organization  @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id         String
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  test_id         String
  test            Test          @relation(fields: [test_id], references: [id], onDelete: Cascade)
  section         Section
  status          AttemptStatus @default(InProgress)
  started_at      DateTime      @default(now())
  submitted_at    DateTime?
  // Optional parent mock session. Standalone practice attempts leave
  // this null; only the mock orchestrator sets it. See ADR 0008 D2.
  mock_session_id String?
  mock_session    MockSession?  @relation(fields: [mock_session_id], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  answers   Answer[]
  grade     Grade?
  recording Recording?

  @@index([org_id])
  @@index([org_id, user_id])
  @@index([org_id, createdAt])
  @@index([org_id, submitted_at])
  @@index([mock_session_id])
}

model Answer {
  id          String       @id @default(cuid())
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  attempt_id  String
  attempt     Attempt      @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question_id String
  question    Question     @relation(fields: [question_id], references: [id], onDelete: Cascade)
  response    Json
  is_correct  Boolean?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([attempt_id, question_id])
  @@index([org_id])
  @@index([attempt_id])
  @@index([question_id])
}

model Grade {
  id                   String       @id @default(cuid())
  org_id               String
  org                  Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  attempt_id           String       @unique
  attempt              Attempt      @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  band_overall         Decimal      @db.Decimal(3, 1)
  criteria_scores_json Json
  feedback_text        String?
  graded_by            GraderKind   @default(AI)
  graded_at            DateTime     @default(now())
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([org_id])
  @@index([org_id, createdAt])
}

model Recording {
  id           String       @id @default(cuid())
  org_id       String
  org          Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  attempt_id   String       @unique
  attempt      Attempt      @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  storage_url  String
  duration_sec Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([org_id])
  @@index([org_id, createdAt])
}

model QuotaUsage {
  id             String       @id @default(cuid())
  org_id         String
  org            Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id        String
  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  ai_calls_count Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([user_id, date])
  @@index([org_id])
  @@index([org_id, date])
}

model ActivityLog {
  id        String       @id @default(cuid())
  org_id    String
  org       Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id   String?
  user      User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  timestamp DateTime     @default(now())

  @@index([org_id])
  @@index([org_id, timestamp])
  @@index([org_id, user_id])
}

// Parent row for a Full Mock Test sitting — see ADR 0008. Standalone
// practice does not create a MockSession; the mock orchestrator is the
// only writer. Section progression / current-section status is derived
// from the joined Attempt rows; this row holds only the lifecycle
// metadata (timing, status, track).
model MockSession {
  id           String       @id @default(cuid())
  org_id       String
  org          Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id      String
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  track        Track
  status       MockStatus   @default(InProgress)
  started_at   DateTime     @default(now())
  submitted_at DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  attempts Attempt[]

  @@index([org_id])
  @@index([org_id, user_id])
  @@index([org_id, status])
}

// One row per successful AI gateway call (chat / realtime mint / TTS /
// transcribe). Powers the cross-org spend column on /metrics. Counts
// in QuotaUsage stay the per-user-per-day quota primitive; this table
// is the money primitive. Pricing lives in packages/ai/src/pricing.ts;
// the gateway writes one row at call completion using cost_usd computed
// from input/output tokens. Unknown models log with cost_usd = 0 and
// surface a console.warn.
model AiCallLog {
  id            String       @id @default(cuid())
  org_id        String
  org           Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  // user_id is nullable because some accounting events (e.g. retries,
  // background jobs) may not have a learner attached. Set null on
  // user deletion so the cost record survives the user row.
  user_id       String?
  user          User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)
  purpose       String
  provider      String
  model         String
  input_tokens  Int          @default(0)
  output_tokens Int          @default(0)
  // Six decimal places fits sub-cent precision for OpenRouter cheap-tier
  // calls (some <$0.0001). Total cap of 10 digits = up to $9,999.999999.
  cost_usd      Decimal      @db.Decimal(10, 6)
  createdAt     DateTime     @default(now())

  @@index([org_id])
  @@index([org_id, createdAt])
  @@index([org_id, purpose])
}

// ─── Compliance models — tenant-scoped (ADR-0019) ─────────────────────────

// Append-only consent ledger. One row per consent state change; the most
// recent row per (user_id, consent_type) is authoritative. Pre-auth cookie
// choices live in a first-party cookie only (no PII server-side) and are
// snapshotted here as rows the first time the chooser is an authenticated
// user, so every persisted row is genuinely org-scoped. We store a salted
// hash of the IP, never the raw address (data minimisation). See ADR-0019 D5.
model ConsentRecord {
  id             String       @id @default(cuid())
  org_id         String
  org            Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id        String
  user           User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  consent_type   ConsentType
  granted        Boolean
  // The policy registry version this consent was given against (e.g.
  // "privacy@2026-06-01"). Lets us re-prompt when a policy materially
  // changes. Free-form so it survives policy renames.
  policy_version String
  // Where the consent was captured: "signup" | "cookie_banner" |
  // "speaking_gate" | "profile" | "guardian".
  source         String
  ip_hash        String?
  user_agent     String?
  createdAt      DateTime     @default(now())

  @@index([org_id])
  @@index([org_id, user_id])
  @@index([org_id, user_id, consent_type])
}

// A data-subject rights request (access / portability / erasure /
// rectification). Erasure is queued rather than instant so it survives a
// short cancellation window before the purge job actions it. Export bundles
// are generated on demand by the route, not stored on this row.
model DataRightsRequest {
  id           String          @id @default(cuid())
  org_id       String
  org          Organization    @relation(fields: [org_id], references: [id], onDelete: Cascade)
  user_id      String
  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type         DataRightType
  status       DataRightStatus @default(Pending)
  // Optional free-text from the requester (e.g. which field to rectify).
  detail       String?
  requested_at DateTime        @default(now())
  fulfilled_at DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([org_id])
  @@index([org_id, user_id])
  @@index([org_id, status])
}
