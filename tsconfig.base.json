{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@elc/ui": ["packages/ui/src/index.ts"],
      "@elc/ui/*": ["packages/ui/src/*"],
      "@elc/db": ["packages/db/src/index.ts"],
      "@elc/db/*": ["packages/db/src/*"],
      "@elc/ai": ["packages/ai/src/index.ts"],
      "@elc/ai/*": ["packages/ai/src/*"]
    }
  }
}
